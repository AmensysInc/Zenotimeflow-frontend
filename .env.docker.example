# Docker Compose environment
# Copy to .env and set values: cp .env.docker.example .env

# ---------------------------------------------------------------------------
# Django (backend)
# ---------------------------------------------------------------------------
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=False
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ---------------------------------------------------------------------------
# MySQL (backend + mysql service)
# ---------------------------------------------------------------------------
USE_SQLITE=0
DB_NAME=zenotimeflow_db
DB_USER=zenotimeflow_user
DB_PASSWORD=changeme
# DB_HOST/DB_PORT set by compose to mysql:3306
MYSQL_ROOT_PASSWORD=rootpassword

# ---------------------------------------------------------------------------
# Redis (backend uses redis service; REDIS_HOST set by compose)
# ---------------------------------------------------------------------------
# REDIS_HOST=redis
# REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
DB_CONN_MAX_AGE=60
# CACHE_TIMEOUT_API=60
